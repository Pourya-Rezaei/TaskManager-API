# ============================================================
#  TaskManager — .gitignore
#  Stack: .NET 10 / C# / SQL Server / React / Docker / K8s
# ============================================================

# ─── .NET / C# ───────────────────────────────────────────────
bin/
obj/
*.user
*.suo
*.userosscache
*.userprefs
*.vs/
.vs/
_ReSharper*/
*.DotSettings.user

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# NuGet
*.nupkg
*.snupkg
.nuget/
packages/
!**/packages/build/
project.lock.json
project.fragment.lock.json
artifacts/

# Rider / JetBrains
.idea/
*.sln.iml

# Roslyn
*.roslynanalyzers

# Test results
TestResults/
*.trx
*.coverage
*.coveragexml
coverage*/
[Tt]est[Rr]esult*/

# ─── ASP.NET Core ────────────────────────────────────────────
# User secrets (فقط روی ماشین محلی)
src/*/Properties/launchSettings.json
secrets.json
appsettings.Development.json
appsettings.Local.json

# ─── Entity Framework ────────────────────────────────────────
# Migration snapshots گاهی نگه داشته می‌شن، اما اگه نمی‌خوای:
# Migrations/

# ─── React / Node.js ─────────────────────────────────────────
node_modules/
dist/
build/
.next/
.nuxt/
.cache/
.parcel-cache/
*.local

# Vite
vite.config.*.timestamp-*

# Package manager logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# ─── Environment files ───────────────────────────────────────
# هیچ‌وقت secret ها رو push نکن!
.env
.env.*
!.env.example
!.env.template

# ─── Docker ──────────────────────────────────────────────────
# فایل‌های اجرایی داکر — فقط override های محلی ignore بشن
docker-compose.override.yml
.docker/

# ─── Kubernetes ──────────────────────────────────────────────
# secret های k8s (مثل kubeconfig محلی)
kubeconfig
*.kubeconfig
k8s/secrets/
k8s/**/secret*.yaml
k8s/**/secret*.yml

# ─── SQL Server ──────────────────────────────────────────────
*.mdf
*.ldf
*.ndf
LocalDB/

# ─── OS ──────────────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ─── Editors ─────────────────────────────────────────────────
# VS Code (اگه تنظیمات شخصی داری)
.vscode/settings.json
.vscode/launch.json
.vscode/extensions.json
# ولی workspace settings عمومی رو می‌تونی نگه داری:
!.vscode/tasks.json

# Vim / Emacs
*.swp
*.swo
*.swn
*#
.#*

# ─── Misc ────────────────────────────────────────────────────
*.bak
*.tmp
*.temp
*.orig
*.log
*.pid
thumbs.db